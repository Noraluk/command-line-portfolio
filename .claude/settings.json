{
  "enabledPlugins": {
    "ponytail@ponytail": false,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npm run --silent lint"
          }
        ]
      }
    ]
  }
}
